{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "bin",
    "rootDir": "src",
    "types": ["@fastly/js-compute"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "src/__tests__"]
}
